# ─────────────────────────────────────────────
# RoundButton: reusable rounded button widget
# Draws its own background via canvas to allow
# full border-radius control and ripple effect
# ─────────────────────────────────────────────
<RoundButton@Button>:
    background_normal: ""
    background_color: (0, 0, 0, 0)        
    canvas.before:
        Color:
            rgba: self.btn_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [self.height / 2]     
    btn_color: (0.9, 0.9, 0.9, 1)         
    on_press:
        # ripple: darken fill by 15% on press
        self.btn_color = [max(0, c - 0.15) for c in self.btn_color[:3]] + [1]
    on_release:
        # ripple: restore original fill on release
        self.btn_color = self.default_color
    default_color: (0.9, 0.9, 0.9, 1)    

FloatLayout:

    # ─────────────────────────────────────────────
    # Root layout: vertical stack of display + grid
    # ─────────────────────────────────────────────
    BoxLayout:
        orientation: "vertical"
        spacing: 0
        padding: 0
        canvas.before:
            Color:
                rgba: 0.96, 0.96, 0.96, 1     
            Rectangle:
                pos: self.pos
                size: self.size

        # ── Display ───────────────────────────────
        # Shows current input or result; right-aligned
        # occupies 30% of screen height
        Label:
            id: display
            text: ""
            size_hint_y: 0.30
            font_size: 56
            color: 0.1, 0.1, 0.1, 1
            halign: "right"
            valign: "bottom"
            text_size: self.size
            padding: [24, 20]

        
        # ── Button Grid ───────────────────────────
        # 4 cols × 5 rows; occupies 70% of screen height
        # Color scheme:
        #   white        → digit buttons
        #   light grey   → utility  (C, >, %, ^)
        #   dark grey    → operators (/ * - +)
        #   green        → equals   (=)
        GridLayout:
            cols: 4
            rows: 5
            size_hint_y: 0.70
            spacing: 14
            padding: [18, 10, 18, 28]

            # ── Row 1: utility | utility | utility | operator ──
            
            # clear
            RoundButton:
                text: "C"                          
                default_color: 0.78, 0.78, 0.78, 1
                btn_color: 0.78, 0.78, 0.78, 1
                color: 0.2, 0.2, 0.2, 1
                font_size: 22
                bold: True
                on_press: app.clear()
            
            # backspace
            RoundButton:
                text: "<"                         
                default_color: 0.78, 0.78, 0.78, 1
                btn_color: 0.78, 0.78, 0.78, 1
                color: 0.2, 0.2, 0.2, 1
                font_size: 22
                on_press: app.backspace()
            
            # mod
            RoundButton:
                text: "%"                          
                default_color: 0.78, 0.78, 0.78, 1
                btn_color: 0.78, 0.78, 0.78, 1
                color: 0.2, 0.2, 0.2, 1
                font_size: 22
            
            # divide
            RoundButton:
                text: "÷"                          
                default_color: 0.30, 0.30, 0.30, 1
                btn_color: 0.30, 0.30, 0.30, 1
                color: 1, 1, 1, 1
                font_size: 26
                on_press: app.press("÷")

            # ── Row 2: digits 7–9 | operator ──
            
            RoundButton:
                text: "7"
                default_color: 1, 1, 1, 1
                btn_color: 1, 1, 1, 1
                color: 0.1, 0.1, 0.1, 1
                font_size: 22
                on_press: app.press("7")
            
            RoundButton:
                text: "8"
                default_color: 1, 1, 1, 1
                btn_color: 1, 1, 1, 1
                color: 0.1, 0.1, 0.1, 1
                font_size: 22
                on_press: app.press("8")
            
            RoundButton:
                text: "9"
                default_color: 1, 1, 1, 1
                btn_color: 1, 1, 1, 1
                color: 0.1, 0.1, 0.1, 1
                font_size: 22
                on_press: app.press("9")
            
            # multiply
            RoundButton:
                text: "×"                          
                default_color: 0.30, 0.30, 0.30, 1
                btn_color: 0.30, 0.30, 0.30, 1
                color: 1, 1, 1, 1
                font_size: 26
                on_press: app.press("×")

            # ── Row 3: digits 4–6 | operator ──
            
            RoundButton:
                text: "4"
                default_color: 1, 1, 1, 1
                btn_color: 1, 1, 1, 1
                color: 0.1, 0.1, 0.1, 1
                font_size: 22
                on_press: app.press("4")
            
            RoundButton:
                text: "5"
                default_color: 1, 1, 1, 1
                btn_color: 1, 1, 1, 1
                color: 0.1, 0.1, 0.1, 1
                font_size: 22
                on_press: app.press("5")
            
            RoundButton:
                text: "6"
                default_color: 1, 1, 1, 1
                btn_color: 1, 1, 1, 1
                color: 0.1, 0.1, 0.1, 1
                font_size: 22
                on_press: app.press("6")
            
            # subtract
            RoundButton:
                text: "−"                          
                default_color: 0.30, 0.30, 0.30, 1
                btn_color: 0.30, 0.30, 0.30, 1
                color: 1, 1, 1, 1
                font_size: 26
                on_press: app.press("−")

            # ── Row 4: digits 1–3 | operator ──
            
            RoundButton:
                text: "1"
                default_color: 1, 1, 1, 1
                btn_color: 1, 1, 1, 1
                color: 0.1, 0.1, 0.1, 1
                font_size: 22
                on_press: app.press("1")
            
            RoundButton:
                text: "2"
                default_color: 1, 1, 1, 1
                btn_color: 1, 1, 1, 1
                color: 0.1, 0.1, 0.1, 1
                font_size: 22
                on_press: app.press("2")
            
            RoundButton:
                text: "3"
                default_color: 1, 1, 1, 1
                btn_color: 1, 1, 1, 1
                color: 0.1, 0.1, 0.1, 1
                font_size: 22
                on_press: app.press("3")
            
            # add
            RoundButton:
                text: "+"                          
                default_color: 0.30, 0.30, 0.30, 1
                btn_color: 0.30, 0.30, 0.30, 1
                color: 1, 1, 1, 1
                font_size: 26
                on_press: app.press("+")

            # ── Row 5: utility | digit 0 | decimal | equals ──
            
            # power
            RoundButton:
                text: "^"                          
                default_color: 0.78, 0.78, 0.78, 1
                btn_color: 0.78, 0.78, 0.78, 1
                color: 0.2, 0.2, 0.2, 1
                font_size: 22
            
            RoundButton:
                text: "0"
                default_color: 1, 1, 1, 1
                btn_color: 1, 1, 1, 1
                color: 0.1, 0.1, 0.1, 1
                font_size: 22
                on_press: app.press("0")
            
            # decimal point
            RoundButton:
                text: "."                          
                default_color: 1, 1, 1, 1
                btn_color: 1, 1, 1, 1
                color: 0.1, 0.1, 0.1, 1
                font_size: 22
                on_press: app.press(".")
            
            # evaluate — green accent
            RoundButton:
                text: "="                          
                default_color: 0.0, 0.62, 0.29, 1
                btn_color: 0.0, 0.62, 0.29, 1
                color: 1, 1, 1, 1
                font_size: 26
                on_press: app.cal()

    # ── FLOATING ERROR LABEL ─────────────────────
    # This floats above everything, you can position anywhere
    Label:
        id: error_label
        text: ""
        size_hint: (0.6, None)  
        height: 0  
        font_size: 24
        color: 1, 1, 1, 1
        halign: "center"
        valign: "middle"
        text_size: self.size
        opacity: 0  
        # Position it anywhere you want (example: center top)
        pos_hint: {'center_x': 0.5, 'top': 0.96}
        canvas.before:
            Color:
                rgba: 0.8, 0.2, 0.2, 1
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [self.height / 2]      
